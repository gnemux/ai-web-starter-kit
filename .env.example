# Environment template
# Copy this file to .env.local for local development and fill in real values there.
# Never commit real secrets, private tokens, customer data, or production credentials.
#
# Vercel environments should be configured separately:
# - Production is used by main branch deployments.
# - Preview is used by manually created PR/commit preview deployments.
# It is acceptable for Production and Preview to temporarily use the same values
# while only one provider environment exists, but keep them as separate Vercel
# environment variable entries so they can diverge later.
#
# NEXT_PUBLIC_* values are exposed to browser code. Only put public config there.

# App metadata
NEXT_PUBLIC_APP_NAME=XWLC
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Allowed values: local, preview, production.
NEXT_PUBLIC_APP_ENV=local
# Allowed values: overseas, china.
NEXT_PUBLIC_APP_MARKET=overseas
NEXT_PUBLIC_APP_VERSION=v0.1
NEXT_PUBLIC_MVP_STAGE=mvp1

# Supabase public client config
# Non-secret project ref used by Supabase CLI link and environment identification.
SUPABASE_PROJECT_REF=nglilxhkuqzswbwitbdu
NEXT_PUBLIC_SUPABASE_URL=https://nglilxhkuqzswbwitbdu.supabase.co
# Preferred public browser key for newer Supabase projects.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy public browser key fallback. Keep only one public key value populated when possible.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-only secrets
# Do not prefix these with NEXT_PUBLIC_ and do not expose them in browser code.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Analytics public config
# Preferred PostHog project key.
NEXT_PUBLIC_POSTHOG_KEY=
# Default for the current PostHog project region. Override only for another PostHog region.
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Optional PostHog compatibility fallback; prefer NEXT_PUBLIC_POSTHOG_KEY.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
# Reserved for China-friendly analytics. Leave empty unless that provider is configured.
NEXT_PUBLIC_JIGUANG_APP_KEY=

# Payments
# Sandbox is the default until a real payment provider is selected.
PAYMENT_PROVIDER=sandbox
# Server-only webhook secret. Do not prefix with NEXT_PUBLIC_.
PAYMENT_WEBHOOK_SECRET=
