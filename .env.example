# Environment template and product-base configuration contract
#
# Copy this file to .env.local for local development and fill in real values
# only in ignored local files or provider dashboards.
# Never commit real secrets, private tokens, customer data, production credentials,
# provider account screenshots, or customer data.
#
# Maintenance rule:
# - When local .env.local changes because the product-base contract changed, update
#   this template and the related docs in context/environment-matrix.md or integrations/*.
# - When local .env.local changes only because one developer uses a different port,
#   local key, or temporary provider value, do not copy that private value here.
# - Every new variable must document whether it is browser-visible NEXT_PUBLIC,
#   server-only, required now, or reserved for a later MVP/provider.
# - Keep related variables in the same provider/module block; do not append new
#   Payment, Supabase, Analytics, AI, Email, Storage, or SMS keys to the bottom.
#
# Vercel environments should be configured separately:
# - Production is used by main branch deployments.
# - Preview is used by manually created PR/commit preview deployments.
# It is acceptable for Production and Preview to temporarily use the same values
# while only one provider environment exists, but keep them as separate Vercel
# environment variable entries so they can diverge later.
#
# NEXT_PUBLIC_* values are exposed to browser code. Only put public config there.
# Server-only secrets, webhook secrets, provider API keys, service-role keys,
# SMTP credentials, storage signing credentials, SMS signing secrets, and AI
# provider keys must never use NEXT_PUBLIC_.

# Public app metadata
# Local:
# - NEXT_PUBLIC_APP_URL should match the port used by `pnpm dev`.
# - NEXT_PUBLIC_APP_ENV must stay local so PostHog local events are labeled env=local.
# Vercel Production:
# - NEXT_PUBLIC_APP_URL must change to the production URL.
# - NEXT_PUBLIC_APP_ENV must change to production.
# - Keep app/product/market/version/mvp_stage aligned with the current product base.
NEXT_PUBLIC_APP_NAME=XWLC
NEXT_PUBLIC_PRODUCT_ID=xwlc
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Allowed values: local, preview, production.
NEXT_PUBLIC_APP_ENV=local
# Allowed values: overseas, china.
NEXT_PUBLIC_APP_MARKET=overseas
NEXT_PUBLIC_APP_VERSION=v0.1
NEXT_PUBLIC_MVP_STAGE=mvp2

# Provider selectors
# These names are non-secret. Configure them separately for local, Vercel Preview,
# and Vercel Production.
# Vercel Production for MVP2 should keep these defaults unless a later issue changes
# the provider boundary: Supabase Auth/Database, PostHog analytics, sandbox Payment,
# mock or no-op AI, and no-op Email/Storage/SMS.
AUTH_PROVIDER=supabase
DATABASE_PROVIDER=supabase
NEXT_PUBLIC_ANALYTICS_PROVIDER=posthog
PAYMENT_PROVIDER=sandbox
PAYMENT_MODE=sandbox
PAYMENT_LIVE_ENABLED=false
AI_PROVIDER=mock
EMAIL_PROVIDER=noop
STORAGE_PROVIDER=noop
SMS_PROVIDER=noop

# Supabase public client config
# Non-secret project ref used by Supabase CLI link and environment identification.
# Local may point to local Supabase or shared staging. Vercel Production must point
# to the intended deployed Supabase project.
SUPABASE_PROJECT_REF=your-supabase-project-ref
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project-ref.supabase.co
# Preferred public browser key for newer Supabase projects.
# Required when NEXT_PUBLIC_SUPABASE_ANON_KEY is empty.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy public browser key fallback.
# Vercel Production does not need this when NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY is set.
# Keep only one public Supabase key populated when possible.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-only secrets
# Do not prefix these with NEXT_PUBLIC_ and do not expose them in browser code.
# Required for server-side Billing/Payment writes in MVP2.
SUPABASE_SECRET_KEY=
# Legacy server-side fallback.
# Vercel Production does not need this when SUPABASE_SECRET_KEY is set.
SUPABASE_SERVICE_ROLE_KEY=

# Analytics public config
# Preferred PostHog project key.
# Required for local/Production analytics. The key is public but should still not be
# pasted into docs, Linear, or screenshots with other secrets.
NEXT_PUBLIC_POSTHOG_KEY=
# Default for the current PostHog project region. Override only for another PostHog region.
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Optional PostHog compatibility fallback.
# Vercel Production does not need this when NEXT_PUBLIC_POSTHOG_KEY is set.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
# Reserved for China-friendly analytics. Leave empty unless that provider is configured.
# Vercel Production does not need this for the overseas/PostHog MVP2 path.
NEXT_PUBLIC_JIGUANG_APP_KEY=

# Payment server-only config
# Sandbox is the default until a real payment provider is selected.
# PAYMENT_MODE must stay sandbox/test until the MVP5 production payment gate.
# PAYMENT_LIVE_ENABLED must stay false for MVP2/MVP3.
#
# Default MVP2 sandbox Vercel Production values:
# - PAYMENT_PROVIDER=sandbox
# - PAYMENT_MODE=sandbox
# - PAYMENT_LIVE_ENABLED=false
# - Leave PAYMENT_PROVIDER_SECRET, PAYMENT_WEBHOOK_SECRET, and Creem product IDs empty.
#
# GNE-100 / PAYMENT-08 Creem test-mode Vercel Production values:
# - PAYMENT_PROVIDER=creem
# - PAYMENT_MODE=test
# - PAYMENT_LIVE_ENABLED=false
# - PAYMENT_PROVIDER_SECRET must be configured in Vercel as a server-only secret.
# - PAYMENT_WEBHOOK_SECRET must be configured in Vercel as a server-only secret.
# - CREEM_*_PRODUCT_ID values must be configured in Vercel; product IDs are not secrets.
# - CREEM_CHECKOUT_SUCCESS_URL must be an HTTPS deployed result URL.
#
# Never put real PAYMENT_PROVIDER_SECRET or PAYMENT_WEBHOOK_SECRET values in this file.
PAYMENT_SECRET_KEY=
# Server-only provider API key for test-mode/live provider work.
# Required in Vercel Production only when PAYMENT_PROVIDER=creem for GNE-100.
# Do not prefix with NEXT_PUBLIC_.
PAYMENT_PROVIDER_SECRET=
# Server-only webhook signing secret.
# Required in Vercel Production only when Creem webhook points at the deployed app.
# Do not prefix with NEXT_PUBLIC_ and do not commit the real value.
PAYMENT_WEBHOOK_SECRET=
# Optional Creem PAYMENT-08 test-mode spike config. Product IDs are not secrets.
# Required in Vercel Production only when PAYMENT_PROVIDER=creem for GNE-100.
# API keys and webhook secrets are still server-only and must stay out of Git.
CREEM_PLUS_MONTHLY_PRODUCT_ID=
CREEM_PRO_MONTHLY_PRODUCT_ID=
CREEM_AI_CREDIT_PACK_100K_PRODUCT_ID=
# HTTPS success URL for Creem hosted checkout redirects.
# Example shape: https://your-domain.example/account/payment/result?status=success
CREEM_CHECKOUT_SUCCESS_URL=

# AI server-only config
# Mock is the default until a later issue selects a real provider.
# Use AI_PROVIDER=noop when the workflow should render without model behavior.
# Vercel Production for MVP2 can keep AI_PROVIDER=mock or noop and leave these empty.
# Add real values only after a real provider issue defines the server-only contract.
# AI_BUDGET_LIMIT is an optional server-only single-request Credit cap. Leave it
# empty for mock/no-op local work; set a numeric cap in provider dashboards before
# real provider smoke tests. Invalid values fail closed as 0 Credit.
AI_MODEL=mock-text
AI_PROVIDER_API_KEY=
AI_BUDGET_LIMIT=

# Email server-only config
# No-op is the default until a product workflow needs email delivery.
# Vercel Production for MVP2 can keep EMAIL_PROVIDER=noop and leave these empty.
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM_ADDRESS=

# Storage server-only config
# No-op is the default until a product workflow needs file storage.
# Vercel Production for MVP2 can keep STORAGE_PROVIDER=noop and leave these empty.
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=

# SMS server-only config
# No-op is the default until a product workflow needs SMS.
# Vercel Production for MVP2 can keep SMS_PROVIDER=noop and leave these empty.
SMS_PROVIDER_API_KEY=
SMS_PROVIDER_SECRET=
SMS_SENDER_ID=
