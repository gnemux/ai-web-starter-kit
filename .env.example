# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
# Non-secret project ref used by Supabase CLI link. Keep real secrets in .env.local or deployment env only.
SUPABASE_PROJECT_REF=nglilxhkuqzswbwitbdu
NEXT_PUBLIC_SUPABASE_URL=https://nglilxhkuqzswbwitbdu.supabase.co
# Prefer the new Supabase publishable key name. Legacy anon key is still supported as a fallback.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
# Default for the current PostHog project region. Override only if the project is created in another region.
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Optional compatibility fallback; prefer NEXT_PUBLIC_POSTHOG_KEY.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_JIGUANG_APP_KEY=

# Payments
PAYMENT_PROVIDER=sandbox
PAYMENT_WEBHOOK_SECRET=
