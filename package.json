{
  "name": "ai-web-starter-kit",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test:ai-safety": "node scripts/verify-ai-safety.mjs",
    "test:package-boundaries": "node scripts/verify-package-boundaries.mjs",
    "test:release-boundaries": "node scripts/verify-release-boundaries.mjs",
    "typecheck": "turbo typecheck",
    "payment:creem:test-checkout": "node integrations/scripts/creem-test-checkout.mjs",
    "template:generate": "node template/generate.mjs",
    "template:compare": "node template/compare.mjs",
    "template:drift": "node template/verify-drift.mjs",
    "template:verify": "node template/verify-candidate.mjs",
    "test:template": "pnpm template:drift && pnpm template:drift -- --negative-fixture && node --test template/tests/*.test.mjs",
    "test": "pnpm test:ai-safety && pnpm test:release-boundaries && pnpm test:package-boundaries && pnpm test:template && turbo test"
  },
  "devDependencies": {
    "ajv": "8.17.1",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  }
}
